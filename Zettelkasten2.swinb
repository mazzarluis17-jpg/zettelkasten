<div class="nb-cell program" data-background="true" name="p11">
% ======================================================
% 9. REGLAS PARA CONSULTAS DEL SISTEMA ZETTELKASTEN
% ======================================================

% Obtener el título de una nota a partir de su slug.
titulo_de(Slug, Titulo) :-
    nota(Titulo, Slug, _, _, _).

% ------------------------------------------------------
% Consulta 1:
% ¿Qué notas pertenecen a una materia?
% Analogía: JOIN entre nota, tema y materia.
% ------------------------------------------------------
notas_de_materia(Materia, Slug, Titulo, Tema) :-
    nota(Titulo, Slug, _, _, _),
    pertenece_a(Slug, Tema),
    es_parte_de(Tema, Materia).

% ------------------------------------------------------
% Consulta 2:
% ¿Quién creó cada nota?
% Analogía: JOIN entre nota y usuario.
% ------------------------------------------------------
autor_de_nota(Slug, Titulo, Autor, Rol) :-
    nota(Titulo, Slug, _, _, _),
    creo(Autor, Slug),
    usuario(Autor, _, Rol).

% ------------------------------------------------------
% Consulta 3:
% ¿Qué notas tienen cierto tag?
% Analogía: nota_tag en PostgreSQL.
% ------------------------------------------------------
notas_con_tag(Tag, Slug, Titulo) :-
    tiene_tag(Slug, Tag),
    titulo_de(Slug, Titulo).

% ------------------------------------------------------
% Consulta 4:
% ¿Cuáles son los links salientes de una nota?
% Analogía: links tipo Obsidian.
% ------------------------------------------------------
links_salientes_de(SlugOrigen, TituloDestino, TipoLink, Contexto) :-
    enlaza(SlugOrigen, SlugDestino, TipoLink, Contexto, _),
    titulo_de(SlugDestino, TituloDestino).

% ------------------------------------------------------
% Consulta 5:
% ¿Cuáles son los backlinks de una nota?
% Importante: el backlink no se guarda, se infiere invirtiendo enlaza/5.
% ------------------------------------------------------
backlinks_de(SlugActual, TituloOrigen, TipoLink, Contexto) :-
    enlaza(SlugOrigen, SlugActual, TipoLink, Contexto, _),
    titulo_de(SlugOrigen, TituloOrigen).
%Autores con tag

% ¿Qué autores tienen notas con cierto tag?
autores_con_tag(Tag, Autor, Rol, Slug, Titulo) :-
    notas_con_tag(Tag, Slug, Titulo),
    autor_de_nota(Slug, Titulo, Autor, Rol).

% ------------------------------------------------------
% Consulta 7:
% ¿Qué autores tienen notas dentro de una materia?
% Usa 2 reglas: notas_de_materia/4 y autor_de_nota/4.
% ------------------------------------------------------
autores_de_materia(Materia, Autor, Rol, Slug, Titulo, Tema) :-
    notas_de_materia(Materia, Slug, Titulo, Tema),
    autor_de_nota(Slug, Titulo, Autor, Rol).

% ------------------------------------------------------
% Consulta 8:
% ¿Qué notas pertenecen a una materia y además tienen cierto tag?
% Usa 2 reglas: notas_de_materia/4 y notas_con_tag/3.
% ------------------------------------------------------
notas_de_materia_con_tag(Materia, Tag, Slug, Titulo, Tema) :-
    notas_de_materia(Materia, Slug, Titulo, Tema),
    notas_con_tag(Tag, Slug, Titulo).
</div>

<div class="nb-cell query" name="q1">
findall(Titulo, notas_de_materia('Inteligencia Artificial', Slug, Titulo, Tema), Lista).
</div>

<div class="nb-cell query" name="q2">
findall(Slug,autor_de_nota(Slug, Titulo,'Bruno Ruiz', Rol), NotasBruno).
</div>

<div class="nb-cell query" name="q3">
findall(Slug, notas_con_tag('neo4j', Slug, Titulo),NotasNeo4j).
</div>

<div class="nb-cell markdown" name="md1">
lista de todas las notas que apuntan hacia “Backlinks estilo Obsidian”.
</div>

<div class="nb-cell query" name="q4">
findall(
   contexto,
    backlinks_de(NotaOrigen,'Backlinks estilo Obsidian', TipoLink,contexto),
    Lista
).
</div>

<div class="nb-cell query" name="q5">
findall(Autor,autores_con_tag('mongodb', Autor, Rol, Slug, Titulo), AutorTag).
</div>

<div class="nb-cell markdown" name="md2">
Autores con Tag
</div>

<div class="nb-cell query" name="q6">
findall(
    fila(Autor, Rol, Slug, Titulo, Tag),
    autores_con_tag('neo4j', Autor, Rol, Slug, Titulo),
    AutorTag
).
</div>

<div class="nb-cell markdown" name="md3">
¿Qué autores tienen notas dentro de una materia?
</div>

<div class="nb-cell query" name="q7">
findall(
    fila(Autor, Rol, Slug, Titulo, Tema, 'Bases de Datos NoSQL'),
    autores_de_materia('Bases de Datos NoSQL', Autor, Rol, Slug, Titulo, Tema),
    Resultado
).
</div>

<div class="nb-cell markdown" name="md4">
notas de Bases de Datos NoSQL que tengan el tag neo4j
</div>

<div class="nb-cell query" name="q8">
findall(
    fila(Slug, Titulo, Tema, 'Bases de Datos NoSQL', 'neo4j'),
    notas_de_materia_con_tag('Bases de Datos NoSQL', 'neo4j', Slug, Titulo, Tema),
    Resultado
).
</div>

</div>
